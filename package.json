{
  "name": "spectrovizard",
  "displayName": "SpectroVizard",
  "description": "Lightweight interactive audio spectrogram visualizer for audio audio analysis, bioacoustics, speech processing, and DSP research.",
  "version": "0.0.2",
  "publisher": "laelume",
  "homepage": "https://github.com/laelume/spectrovizard",
  "repository": {
    "type": "git",
    "url": "https://github.com/laelume/spectrovizard"
  }, 
  "bugs": {
    "url": "https://github.com/laelume/spectrovizard/issues"
  },
  "license": "MIT",
  "icon": "img/spectrovizard_icon.jpg",
  "engines": { "vscode": "^1.85.0" },
  "categories": [
    "Visualization", 
    "Data Science", 
    "Machine Learning"
  ],
  "keywords": [
    "audio","audio-visualization","spectrogram",
    "waveform","signal-processing","dsp","speech",
    "speech-analysis","bioacoustics","acoustics",
    "birdsong","animal-communication","audio-analysis",
    "fft","frequency-analysis","sonogram","machine-learning",
    "research","phonetics","phonology","linguistics",
    "ecoacoustics","wildlife-audio","audio-research",
    "time-frequency-analysis","passive-acoustic-monitoring",
    "pam"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "customEditors": [
      {
        "viewType": "spectrovizard.spectroView",
        "displayName": "SpectroVizard",
        "selector": [
          { "filenamePattern": "*.wav" },
          { "filenamePattern": "*.mp3" },
          { "filenamePattern": "*.flac" },
          { "filenamePattern": "*.ogg" },
          { "filenamePattern": "*.m4a" },
          { "filenamePattern": "*.aac" },
          { "filenamePattern": "*.pcm" }
        ],
        "priority": "default"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0"
  }
}